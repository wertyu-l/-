<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="com.example.demo.ST.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="role" property="role"/>
        <result column="user_type" property="userType"/>
        <result column="user_level" property="userLevel"/>
        <result column="department" property="department"/>
        <result column="position" property="position"/>
        <result column="phone" property="phone"/>
        <result column="email" property="email"/>
        <result column="is_enabled" property="isEnabled"/>
        <result column="valid_until" property="validUntil"/>
        <result column="login_status" property="loginStatus"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (username, password, role, user_type, user_level, department, position, phone, email, is_enabled, valid_until, login_status)
        VALUES (#{username}, #{password}, #{role}, #{userType}, #{userLevel}, #{department}, #{position}, #{phone}, #{email}, #{isEnabled}, #{validUntil}, #{loginStatus})
    </insert>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM user WHERE id = #{id}
    </select>

    <select id="findByUsername" resultMap="BaseResultMap">
        SELECT * FROM user WHERE username = #{username}
    </select>

    <update id="updateById">
        UPDATE user
        SET username = #{username},
            password = #{password},
            role = #{role},
            user_type = #{userType},
            user_level = #{userLevel},
            department = #{department},
            position = #{position},
            phone = #{phone},
            email = #{email},
            is_enabled = #{isEnabled},
            valid_until = #{validUntil},
            login_status = #{loginStatus}
        WHERE id = #{id}
    </update>

    <delete id="deleteByUsername">
        DELETE FROM user WHERE username = #{username}
    </delete>

    <select id="pageQuery" resultMap="BaseResultMap">
        SELECT * FROM user
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
        </where>
        ORDER BY id DESC
    </select>

</mapper>